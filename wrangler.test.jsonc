{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fauna-archive-test",
  "main": "apps/worker/src/index.tsx",
  "compatibility_date": "2026-02-24",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "development",
    "SITE_URL": "http://example.test",
    "ACCESS_TEAM_DOMAIN": "",
    "ACCESS_AUD": "",
    "TURNSTILE_SITE_KEY": "",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "fauna-archive-test",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "fauna-archive-test-media",
    },
  ],
}
